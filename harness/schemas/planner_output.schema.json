{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lane",
    "summary",
    "scope",
    "files_of_interest",
    "acceptance_criteria",
    "verification_plan",
    "risks"
  ],
  "properties": {
    "lane": {
      "type": "string",
      "enum": [
        "backend",
        "frontend",
        "frontend-next",
        "solver-v4",
        "cross-layer",
        "docs"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "files_of_interest": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "verification_plan": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
