{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "commands_run",
    "blocking_findings",
    "non_blocking_findings",
    "recommended_next_action"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "exit_code",
          "outcome"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer"
          },
          "outcome": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_blocking_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_next_action": {
      "type": "string",
      "minLength": 1
    }
  }
}
