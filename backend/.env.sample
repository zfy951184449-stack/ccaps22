# MFG8APS Backend 环境变量样例。
# 复制为 .env 后按本地/部署环境填值。切勿把真实密钥提交进仓库。

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=aps_system
DB_CHARSET=utf8mb4_general_ci
DATABASE_URL="mysql://root:@localhost:3306/aps_system"

# --- Server ---
HOST=0.0.0.0
PORT=3001
# 逗号分隔的允许来源；留空=允许所有（仅开发）。
CORS_ALLOWED_ORIGINS=

# --- Solver ---
SOLVER_V4_URL=http://localhost:5005

# --- Resource feature flags ---
ENABLE_TEMPLATE_RESOURCE_RULES=true
ENABLE_BATCH_RESOURCE_SNAPSHOTS=
ENABLE_RUNTIME_RESOURCE_SNAPSHOT_READ=

# --- Holiday API ---
TIANAPI_KEY=
TIAN_API_KEY=

# --- Auth (认证接入层) ---
# JWT 签名密钥：必填且非空。缺失时 JwtService 在模块加载阶段抛错，server 无法启动。
# 生成：openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
# 令牌有效期（jsonwebtoken 时长字符串或秒数），默认 8h。
JWT_EXPIRES_IN=8h
# 令牌 issuer / audience，默认 mfg8aps / mfg8aps-web。
JWT_ISSUER=mfg8aps
JWT_AUDIENCE=mfg8aps-web
# 认证强制开关。默认 false=影子模式（验签挂 req.user，但不拦无/坏 token）。
# 设为 true 时全量强制：无/坏 token 的受保护请求返回 401。
AUTH_ENFORCE=false
# 本地登录失败锁定阈值与时长（有默认值）。
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
# solver→backend 回调共享密钥（requireServiceAuth 校验 X-Solver-Callback-Token）。
# 须与 solver 侧一致；未配置时机器回调返回 503。生成：openssl rand -hex 32
SOLVER_CALLBACK_SECRET=replace-with-openssl-rand-hex-32

# --- Frontend (CRA) ---
# REACT_APP_MONTH_TOLERANCE_HOURS=8
