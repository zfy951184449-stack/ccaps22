{
  "name": "aps-backend",
  "version": "1.0.0",
  "description": "APS System Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:ci": "vitest run src/tests/templateResourceRoutes.test.ts src/tests/processTemplateWorkbookService.test.ts src/tests/qualificationRoutes.test.ts",
    "test:db": "vitest run src/tests/batchLifecycleService.test.ts",
    "migrate:metrics": "sh -ac 'set -a; [ -f .env ] && . ./.env; set +a; MYSQL_PWD=\"${DB_PASSWORD:-${MYSQL_PASSWORD:-}}\" mysql -h\"${DB_HOST:-localhost}\" -P\"${DB_PORT:-3306}\" -u\"${DB_USER:-${MYSQL_USER:-root}}\" \"${DB_NAME:-${MYSQL_DATABASE:-aps_system}}\" < ../database/create_personnel_scheduling_tables.sql'",
    "migrate:personnel": "sh -ac 'set -a; [ -f .env ] && . ./.env; set +a; MYSQL_PWD=\"${DB_PASSWORD:-${MYSQL_PASSWORD:-}}\" mysql -h\"${DB_HOST:-localhost}\" -P\"${DB_PORT:-3306}\" -u\"${DB_USER:-${MYSQL_USER:-root}}\" \"${DB_NAME:-${MYSQL_DATABASE:-aps_system}}\" < ../database/update_personnel_scheduling_schema.sql'",
    "migrate:special-shifts": "sh -ac 'set -a; [ -f .env ] && . ./.env; set +a; MYSQL_PWD=\"${DB_PASSWORD:-${MYSQL_PASSWORD:-}}\" mysql -h\"${DB_HOST:-localhost}\" -P\"${DB_PORT:-3306}\" -u\"${DB_USER:-${MYSQL_USER:-root}}\" \"${DB_NAME:-${MYSQL_DATABASE:-aps_system}}\" < ../database/migrations/20260303_create_special_shift_window_tables.sql && MYSQL_PWD=\"${DB_PASSWORD:-${MYSQL_PASSWORD:-}}\" mysql -h\"${DB_HOST:-localhost}\" -P\"${DB_PORT:-3306}\" -u\"${DB_USER:-${MYSQL_USER:-root}}\" \"${DB_NAME:-${MYSQL_DATABASE:-aps_system}}\" < ../database/migrations/20260304_expand_special_shift_window_joint_solve.sql'"
  },
  "dependencies": {
    "@types/eventsource": "^1.1.15",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.18",
    "dotenv": "^16.6.1",
    "eventsource": "^4.1.0",
    "express": "^4.18.0",
    "http-proxy-middleware": "^3.0.5",
    "multer": "^2.1.1",
    "mysql2": "^3.18.2",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "supertest": "^7.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
