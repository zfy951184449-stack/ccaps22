{
  "name": "frontend-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -c 'next dev --hostname ${HOST:-0.0.0.0} --port ${PORT:-3002}'",
    "build": "next build",
    "start": "sh -c 'next start --hostname ${HOST:-0.0.0.0} --port ${PORT:-3002}'",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run",
    "storybook": "storybook dev -p 6100 --ci",
    "storybook:build": "storybook build",
    "e2e": "playwright test",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/react": "^0.27.19",
    "@svar-ui/react-gantt": "^2.6.1",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/nextjs": "^10.3.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "storybook": "^10.3.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
