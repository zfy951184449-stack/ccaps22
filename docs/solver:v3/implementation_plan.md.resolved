**自动验证脚本**:
```bash
#!/bin/bash
# test_sprint_2c.sh
cd solver_v3

echo "=== 检查容量约束模块 ==="
python3 -c "from constraints.capacity.monthly_hours import MonthlyHoursConstraint; print('✅ H8-H9 月度工时约束')" || echo "❌ H8-H9 失败"
python3 -c "from constraints.assignment.sharing import SharingConstraint; print('✅ H10 共享组约束')" || echo "❌ H10 失败"

echo -e "\n=== 整合测试 ==="
# 测试: 所有硬约束应可加载
python3 -c "
from core.engine import SolverEngine
from constraints import CONSTRAINT_REGISTRY
print(f'✅ 已注册 {len(CONSTRAINT_REGISTRY)} 个约束模块')
" || echo "❌ 约束注册失败"

# 测试完整求解流程
curl -s -X POST http://localhost:5002/api/v3/solve -H "Content-Type: application/json" -d '{
  "operations": [{"id":1, "required_people":2, "planned_start":"2025-01-15T09:00:00", "planned_end":"2025-01-15T12:00:00"}],
