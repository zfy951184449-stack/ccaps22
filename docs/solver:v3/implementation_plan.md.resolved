  "config": {"enforce_qualification": false}
}' | python3 -c "import sys,json; d=json.load(sys.stdin); print('✅ 完整求解流程正常' if d.get('status') in ['OPTIMAL','FEASIBLE','MOCK'] else '❌ 求解失败')"
